{
  "name": "ghlog-ts",
  "version": "0.1.0",
  "description": "",
  "bin": {
    "ghlog-ts": "./dist/index.js"
  },
  "imports": {
    "#auth": "./dist/auth.js",
    "#commands/*": "./dist/commands/*.js",
    "#domain/*": "./dist/domain/*.js",
    "#errors": "./dist/errors.js",
    "#result": "./dist/result.js",
    "#services/*": "./dist/services/*.js"
  },
  "scripts": {
