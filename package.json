{
  "name": "ghlog-ts",
  "version": "0.1.0",
  "description": "",
  "bin": {
    "ghlog-ts": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json",
    "ci": "biome ci src vitest.config.ts",
    "dev": "tsx src/index.ts",
    "format": "biome format --write src test vitest.*.ts",
    "lint:fix": "biome check --write src test vitest.*.ts",
    "lint": "biome check src test vitest.*.ts",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "zod": "^4.4.3"
  }
}
